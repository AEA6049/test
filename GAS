function processAttendance(payload) {
  var ss = getSpreadsheet();
  var sheetMurid = ss.getSheetByName('nama murid');
  var sheetGuru = ss.getSheetByName('guru');
  var sheetPelaporan = ss.getSheetByName('pelaporan');
  var sheetSejarah = ss.getSheetByName('sejarah_kehadiran');
  
  var muridList = payload.muridData;
  var dataMurid = sheetMurid.getDataRange().getValues();
  var tarikhPilihan = payload.tarikh; 
  var todayStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd");
  
  var isHariSemasa = (tarikhPilihan === todayStr);

  var historyData = sheetSejarah.getDataRange().getValues();
  var rowIndexSejarah = -1;
  var oldDataMap = {};

  for(var h=1; h<historyData.length; h++) {
    var rowDate = "";
    try { rowDate = Utilities.formatDate(new Date(historyData[h][0]), Session.getScriptTimeZone(), "yyyy-MM-dd"); } catch(e){}
    if(rowDate === tarikhPilihan && historyData[h][1].toString() === payload.kelas) {
      rowIndexSejarah = h + 1;
      try {
        var oldArr = JSON.parse(historyData[h][3]);
        oldArr.forEach(function(item) { oldDataMap[item.nama.toUpperCase()] = item; });
      } catch(e) {}
      break;
    }
  }

  var starPointsGuru = 0;

  muridList.forEach(function(newM) {
    if (isHariSemasa) {
      var upperNama = newM.nama.toUpperCase();
      var oldM = oldDataMap[upperNama];
      
      // Logik markah: 1 point untuk setiap ejas bintang per murid.
      // Anggap default adalah 3 jika tiada rekod lama dan murid hadir.
      var oldBintang = oldM ? oldM.bintang : (newM.hadir ? 3 : 0);
      var bezaBintang = newM.bintang - (oldM ? oldM.bintang : 0); // Beza sebenar untuk rekod pelajar

      if (newM.hadir && newM.bintang !== oldBintang) {
          starPointsGuru += 1;
      }

      for(var i=1; i<dataMurid.length; i++) {
        if(dataMurid[i][0].toString().toUpperCase() === upperNama) {
          var currentTotal = parseInt(dataMurid[i][2]) || 0;
          sheetMurid.getRange(i+1, 3).setValue(currentTotal + bezaBintang);
          sheetMurid.getRange(i+1, 4).setValue(todayStr);
          sheetMurid.getRange(i+1, 5).setValue(newM.bintang);
          break;
        }
      }
    }
  });

  if (rowIndexSejarah > -1) {
    sheetSejarah.getRange(rowIndexSejarah, 3).setValue(payload.guru);
    sheetSejarah.getRange(rowIndexSejarah, 4).setValue(JSON.stringify(muridList));
  } else {
    sheetSejarah.appendRow([tarikhPilihan, payload.kelas, payload.guru, JSON.stringify(muridList)]);
  }

  var attendancePoints = 0;
  if (isHariSemasa) {
    var pelaporanData = sheetPelaporan.getDataRange().getValues();
    var alreadySubmittedToday = false;
    for(var r = 1; r < pelaporanData.length; r++) {
      if (pelaporanData[r][0]) {
        try {
          var pDate = Utilities.formatDate(new Date(pelaporanData[r][0]), Session.getScriptTimeZone(), "yyyy-MM-dd");
          var pType = pelaporanData[r][1] ? pelaporanData[r][1].toString() : "";
          var pGuru = pelaporanData[r][2] ? pelaporanData[r][2].toString() : "";
          // Semak jika guru telah terima 5 point kehadiran hari ini
          if(pDate === todayStr && pType === 'Kehadiran Harian' && pGuru === payload.guru) {
            alreadySubmittedToday = true;
            break;
          }
        } catch (e) {}
      }
    }
    if(!alreadySubmittedToday) {
        attendancePoints = 5; // 5 point maksima sehari untuk kehadiran
    }
  }
  
  var totalPoints = attendancePoints + starPointsGuru;
  if (totalPoints > 0 && isHariSemasa) {
     updateTeacherPoints(sheetGuru, payload.guru, totalPoints);
  }

  var gpsLink = payload.gps;
  if (payload.gps && payload.gps.indexOf(',') > -1) {
      gpsLink = '=HYPERLINK("https://www.google.com/maps?q=' + payload.gps.replace(/\s/g, '') + '", "Buka Peta")';
  }

  var logType = isHariSemasa ? 'Kehadiran Harian' : 'Kehadiran Harian (Rekod Lepas)';
  if (attendancePoints > 0 || !isHariSemasa) {
      sheetPelaporan.appendRow([new Date(), logType, payload.guru, payload.kelas, 'Penghantaran log kehadiran. Tarikh Data: ' + tarikhPilihan, gpsLink, attendancePoints]);
  }
  
  if (starPointsGuru > 0 && isHariSemasa) {
      sheetPelaporan.appendRow([new Date(), 'Kemaskini Bintang', payload.guru, payload.kelas, 'Kemaskini manual bintang pelajar. Tarikh Data: ' + tarikhPilihan, gpsLink, starPointsGuru]);
  }
  
  return { success: true, pointsEarned: totalPoints };
}

function processReport(payload) {
  var ss = getSpreadsheet();
  var sheetGuru = ss.getSheetByName('guru');
  var sheetPelaporan = ss.getSheetByName('pelaporan');
  
  var todayStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd");
  var isHariSemasa = (payload.tarikh === todayStr);

  var wordCount = payload.ulasan ? payload.ulasan.trim().split(/\s+/).length : 0;
  var textPoints = wordCount >= 100 ? 5 : (wordCount > 0 ? 2 : 0);
  var filePoints = payload.files ? payload.files.length : 0;
  var earnedPoints = isHariSemasa ? (textPoints + filePoints) : 0;
  
  if (earnedPoints > 0) {
    updateTeacherPoints(sheetGuru, payload.guru, earnedPoints);
  }
  
  var fileUrls = [];
  if (payload.files && payload.files.length > 0 && SCRIPT_CONFIG.FOLDER_ID !== "") {
    try {
      var folder = DriveApp.getFolderById(SCRIPT_CONFIG.FOLDER_ID);
      payload.files.forEach(function(f) {
        var safeName = (f.name || 'Lampiran_' + new Date().getTime()).replace(/\[|\]|\|/g, '');
        var blob = Utilities.newBlob(Utilities.base64Decode(f.data), f.mimeType, safeName);
        var file = folder.createFile(blob);
        
        // PENTING: Cubaan untuk menetapkan akses Public (ANYONE_WITH_LINK) supaya QR boleh diimbas.
        try {
           file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
        } catch(shareErr) {
           Logger.log("Gagal menetapkan kebenaran fail, semak polisi workspace: " + shareErr);
        }
        
        if (f.mimeType.indexOf('image/') > -1) {
           fileUrls.push("[IMAGE|" + safeName + "]https://drive.google.com/thumbnail?id=" + file.getId() + "&sz=w1000");
        } else {
           fileUrls.push("[FILE|" + safeName + "]" + file.getUrl());
        }
      });
    } catch(e) {
      fileUrls.push("Ralat Muat Naik: " + e.toString());
    }
  }
  
  var lampiranText = fileUrls.length > 0 ? fileUrls.join("\n") : "Tiada Lampiran";
  var info = "Ulasan: " + (payload.ulasan || "Tiada") + " \n\nLampiran:\n" + lampiranText;
  
  var gpsLink = payload.gps;
  if (payload.gps && payload.gps.indexOf(',') > -1) {
      gpsLink = '=HYPERLINK("https://www.google.com/maps?q=' + payload.gps.replace(/\s/g, '') + '", "Buka Peta")';
  }
  
  var logType = isHariSemasa ? 'Dokumentasi Sesi' : 'Dokumentasi Sesi (Rekod Lepas)';
  sheetPelaporan.appendRow([
    new Date(), 
    logType,
    payload.guru, 
    payload.kelas, 
    info, 
    gpsLink, 
    earnedPoints
  ]);
  
  return { success: true, pointsEarned: earnedPoints };
}

function updateReport(payload) {
  var sheet = getSpreadsheet().getSheetByName('pelaporan');
  var data = sheet.getDataRange().getValues();
  
  var fileUrls = payload.oldAttachments || [];
  if (payload.files && payload.files.length > 0 && SCRIPT_CONFIG.FOLDER_ID !== "") {
    var folder = DriveApp.getFolderById(SCRIPT_CONFIG.FOLDER_ID);
    payload.files.forEach(function(f) {
      var safeName = (f.name || 'Lampiran_' + new Date().getTime()).replace(/\[|\]|\|/g, '');
      var blob = Utilities.newBlob(Utilities.base64Decode(f.data), f.mimeType, safeName);
      var file = folder.createFile(blob);
      
      // PENTING: Benarkan Akses Secara Awam
      try {
         file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
      } catch(shareErr) {
         Logger.log("Gagal menetapkan kebenaran fail: " + shareErr);
      }
      
      if (f.mimeType.indexOf('image/') > -1) {
         fileUrls.push("[IMAGE|" + safeName + "]https://drive.google.com/thumbnail?id=" + file.getId() + "&sz=w1000");
      } else {
         fileUrls.push("[FILE|" + safeName + "]" + file.getUrl());
      }
    });
  }
  
  var lampiranText = fileUrls.length > 0 ? fileUrls.join("\n") : "Tiada Lampiran";
  var info = "Ulasan: " + (payload.ulasan || "Tiada") + " \n\nLampiran:\n" + lampiranText;
  
  for(var i=data.length-1; i>=1; i--) {
    var rowTime = "";
    var rowDate = "";
    try {
      rowTime = Utilities.formatDate(new Date(data[i][0]), Session.getScriptTimeZone(), "hh:mm a");
      rowDate = Utilities.formatDate(new Date(data[i][0]), Session.getScriptTimeZone(), "yyyy-MM-dd");
    } catch(e) {}
    
    if(rowTime === payload.timestamp && data[i][2].toString() === payload.guru && data[i][3].toString() === payload.kelas && rowDate === payload.tarikh) {
      sheet.getRange(i+1, 5).setValue(info);
      return { success: true };
    }
  }
  return { success: false, error: "Laporan asal tidak ditemui dalam pangkalan data." };
}

function getReportHistory(payload) {
  var sheet = getSpreadsheet().getSheetByName('pelaporan');
  var data = sheet.getDataRange().getValues();
  var results = [];
  
  var attSheet = getSpreadsheet().getSheetByName('sejarah_kehadiran');
  var attData = attSheet.getDataRange().getValues();
  var attMap = {}; 
  for(var a=1; a<attData.length; a++) {
     try {
       var aDate = Utilities.formatDate(new Date(attData[a][0]), Session.getScriptTimeZone(), "yyyy-MM-dd");
       var aKelas = attData[a][1].toString();
       attMap[aDate + "_" + aKelas] = attData[a][3]; 
     } catch(e){}
  }
  
  for(var i=data.length-1; i>=1; i--) {
    var rowDate = "";
    try { rowDate = Utilities.formatDate(new Date(data[i][0]), Session.getScriptTimeZone(), "yyyy-MM-dd"); } catch(e){}
    if(rowDate === payload.tarikh && data[i][1].toString().indexOf('Dokumentasi Sesi') > -1) {
      var pureGps = data[i][5].toString();
      if(pureGps.indexOf('HYPERLINK') > -1) {
         var match = pureGps.match(/"([^"]+)"/);
         if(match) pureGps = match[1];
      }

      var key = payload.tarikh + "_" + data[i][3].toString();
      var kehadiranSummary = "Tiada Rekod Kehadiran Disimpan";
      if(attMap[key]) {
         try {
           var mList = JSON.parse(attMap[key]);
           var hadir = 0, takHadir = 0;
           mList.forEach(function(m){ if(m.hadir) hadir++; else takHadir++; });
           kehadiranSummary = hadir + " Hadir | " + takHadir + " Tidak Hadir";
         } catch(e){}
      }

      results.push({
        timestamp: Utilities.formatDate(new Date(data[i][0]), Session.getScriptTimeZone(), "hh:mm a"),
        guru: data[i][2],
        kelas: data[i][3],
        maklumat: data[i][4],
        gps: pureGps,
        kehadiranSummary: kehadiranSummary
      });
    }
  }
  return { success: true, data: results };
}

function getDriveImageBase64(payload) {
  try {
     var idMatch = payload.url.match(/id=([^&]+)/);
     if(!idMatch) return { success: false, error: "Tiada ID ditemui" };
     var fileId = idMatch[1];
     var file = DriveApp.getFileById(fileId);
     var base64 = Utilities.base64Encode(file.getBlob().getBytes());
     var mime = file.getMimeType();
     return { success: true, base64: "data:" + mime + ";base64," + base64 };
  } catch(e) {
     // Jika akses gagal atau ralat berlaku, kembalikan gambar placeholder (Base64 Pixel Kelabu)
     var fallbackBase64 = "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=";
     return { success: true, base64: fallbackBase64, error_log: e.toString() };
  }
}

/**
 * FUNGSI UJIAN KHAS UNTUK MENYEMAK KEBENARAN AKSES GOOGLE DRIVE (FILE ID)
 */
function testFileAccess(payload) {
  try {
    var file = DriveApp.getFileById(payload.fileId);
    var access = file.getSharingAccess();
    var permission = file.getSharingPermission();
    return {
      success: true,
      name: file.getName(),
      access: access.toString(),
      permission: permission.toString()
    };
  } catch(e) {
    return { success: false, error: e.toString() };
  }
}
