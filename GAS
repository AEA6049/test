function _authorizeDriveAccess() {
  var files = DriveApp.getFiles();
  if(files.hasNext()) { Logger.log("Berjaya dapatkan akses untuk: " + files.next().getName()); }
}

function getSpreadsheet() {
  if (SCRIPT_CONFIG.SPREADSHEET_ID !== "") {
    return SpreadsheetApp.openById(SCRIPT_CONFIG.SPREADSHEET_ID);
  } else {
    return SpreadsheetApp.getActiveSpreadsheet();
  }
}

function doGet(e) {
  if (e && e.parameter && e.parameter.action === 'getInitialData') {
    return ContentService.createTextOutput(JSON.stringify(getInitialData()))
      .setMimeType(ContentService.MimeType.JSON);
  }
  return HtmlService.createHtmlOutputFromFile('Index')
    .setTitle('YAYASAN SULTAN AZLAN SHAH - SMK SUNGAI BAYO')
    .addMetaTag('viewport', 'width=device-width, initial-scale=1');
}

function doPost(e) {
  try {
    var action = e.parameter.action;
    var payload = JSON.parse(e.postData.contents);
    var result = {};

    if (action === 'addMurid') result = addMurid(payload);
    else if (action === 'updateMurid') result = updateMurid(payload);
    else if (action === 'deleteMurid') result = deleteMurid(payload);
    else if (action === 'processAttendance') result = processAttendance(payload);
    else if (action === 'processReport') result = processReport(payload);
    else if (action === 'updateReport') result = updateReport(payload);
    else if (action === 'getAttendanceHistory') result = getAttendanceHistory(payload);
    else if (action === 'getReportHistory') result = getReportHistory(payload);
    else if (action === 'getDriveImageBase64') result = getDriveImageBase64(payload);
    else if (action === 'testFileAccess') result = testFileAccess(payload);

    return ContentService.createTextOutput(JSON.stringify(result))
      .setMimeType(ContentService.MimeType.JSON);
  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({ error: err.toString() }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

function checkAndCreateSheets(ss) {
  if (!ss.getSheetByName('nama murid')) ss.insertSheet('nama murid').appendRow(['Nama Murid', 'Nama Kelas', 'Prestasi Terkumpul', 'Tarikh Terakhir Update', 'Bintang Terakhir', 'Gambar URL']);
  if (!ss.getSheetByName('guru')) ss.insertSheet('guru').appendRow(['Nama Guru', 'Prestasi Guru']);
  if (!ss.getSheetByName('pelaporan')) ss.insertSheet('pelaporan').appendRow(['Timestamp', 'Jenis Laporan', 'Nama Guru', 'Nama Kelas', 'Maklumat', 'Lokasi GPS Map', 'Point Tambahan']);
  if (!ss.getSheetByName('sejarah_kehadiran')) ss.insertSheet('sejarah_kehadiran').appendRow(['Tarikh', 'Nama Kelas', 'Nama Guru', 'Data JSON Kehadiran']);
}

function getInitialData() {
  var ss = getSpreadsheet();
  checkAndCreateSheets(ss);
  
  var sheetMurid = ss.getSheetByName('nama murid').getDataRange().getValues();
  var sheetGuru = ss.getSheetByName('guru').getDataRange().getValues();
  
  var murid = [];
  for(var i=1; i<sheetMurid.length; i++) {
    if (sheetMurid[i][0]) {
      var tarikhStr = "";
      if(sheetMurid[i][3]) {
        try {
          tarikhStr = Utilities.formatDate(new Date(sheetMurid[i][3]), Session.getScriptTimeZone(), "yyyy-MM-dd");
        } catch(e) {}
      }
      
      var gambarUrl = sheetMurid[i][5] ? sheetMurid[i][5].toString() : null;

      murid.push({
        nama: sheetMurid[i][0].toString().toUpperCase(),
        kelas: sheetMurid[i][1].toString(),
        prestasi: parseInt(sheetMurid[i][2]) || 0,
        tarikhTerakhir: tarikhStr,
        bintangTerakhir: parseInt(sheetMurid[i][4]) || 0,
        gambar: gambarUrl
      });
    }
  }
  
  var guru = [];
  for(var j=1; j<sheetGuru.length; j++) {
    if (sheetGuru[j][0]) guru.push(sheetGuru[j][0].toString());
  }
  
  return { murid: murid, guru: guru };
}

function addMurid(payload) {
  var ss = getSpreadsheet();
  var sheet = ss.getSheetByName('nama murid');
  var sheetGuru = ss.getSheetByName('guru');
  var upperNama = payload.nama.toUpperCase();
  var todayStr = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd");
  var fileUrl = "";
  var pointsEarned = 0;

  if (payload.gambarData && SCRIPT_CONFIG.FOLDER_ID !== "") {
    try {
      var folder = DriveApp.getFolderById(SCRIPT_CONFIG.FOLDER_ID);
      var blob = Utilities.newBlob(Utilities.base64Decode(payload.gambarData), payload.gambarMime, 'Murid_' + upperNama.replace(/[^a-zA-Z0-9]/g, '_') + '_' + new Date().getTime());
      var file = folder.createFile(blob);
      try { file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW); } catch(e){}
      fileUrl = "https://drive.google.com/thumbnail?id=" + file.getId() + "&sz=w1000";

      if (payload.guru) {
         updateTeacherPoints(sheetGuru, payload.guru, 1);
         pointsEarned = 1;
      }
    } catch(e) {
       Logger.log("Gagal upload gambar murid: " + e.toString());
    }
  }

  // Murid baharu diberikan automatik 3 bintang secara lalaian (default)
  sheet.appendRow([upperNama, payload.kelas, 3, todayStr, 3, fileUrl]);
  return { success: true, pointsEarned: pointsEarned };
}

function updateMurid(payload) {
  var ss = getSpreadsheet();
  var sheet = ss.getSheetByName('nama murid');
  var sheetGuru = ss.getSheetByName('guru');
  var data = sheet.getDataRange().getValues();
  var upperNama = payload.nama.toUpperCase();
  var oldUpperNama = payload.oldNama.toUpperCase();
  var pointsEarned = 0;

  var fileUrl = null;
  if (payload.gambarData && SCRIPT_CONFIG.FOLDER_ID !== "") {
    try {
      var folder = DriveApp.getFolderById(SCRIPT_CONFIG.FOLDER_ID);
      var blob = Utilities.newBlob(Utilities.base64Decode(payload.gambarData), payload.gambarMime, 'Murid_' + upperNama.replace(/[^a-zA-Z0-9]/g, '_') + '_' + new Date().getTime());
      var file = folder.createFile(blob);
      try { file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW); } catch(e){}
      fileUrl = "https://drive.google.com/thumbnail?id=" + file.getId() + "&sz=w1000";

      if (payload.guru) {
         updateTeacherPoints(sheetGuru, payload.guru, 1);
         pointsEarned = 1;
      }
    } catch(e) {
       Logger.log("Gagal upload gambar murid: " + e.toString());
    }
  }

  for(var i=1; i<data.length; i++) {
    if(data[i][0].toString().toUpperCase() === oldUpperNama) {
      sheet.getRange(i+1, 1).setValue(upperNama);
      sheet.getRange(i+1, 2).setValue(payload.kelas);
      if (fileUrl) {
         sheet.getRange(i+1, 6).setValue(fileUrl);
      }
      break;
    }
  }
  return { success: true, pointsEarned: pointsEarned };
}

function deleteMurid(payload) {
  var sheet = getSpreadsheet().getSheetByName('nama murid');
  var data = sheet.getDataRange().getValues();
  var upperNama = payload.nama.toUpperCase();
  for(var i=1; i<data.length; i++) {
    if(data[i][0].toString().toUpperCase() === upperNama) {
      sheet.deleteRow(i+1);
      break;
    }
  }
  return { success: true };
}

function updateTeacherPoints(sheetGuru, namaGuru, pointsToAdd) {
  var data = sheetGuru.getDataRange().getValues();
  var found = false;
  for(var i=1; i<data.length; i++) {
    if(data[i][0].toString() === namaGuru) {
      var curr = parseInt(data[i][1]) || 0;
      sheetGuru.getRange(i+1, 2).setValue(curr + pointsToAdd);
      found = true;
      break;
    }
  }
  if(!found && namaGuru) sheetGuru.appendRow([namaGuru, pointsToAdd]);
}

function getAttendanceHistory(payload) {
  var sheet = getSpreadsheet().getSheetByName('sejarah_kehadiran');
  var data = sheet.getDataRange().getValues();
